# Shroud Protocol – Environment Variables
# Copy to .env and fill in values before running scripts

# RPC endpoint for Arbitrum Sepolia
RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Private key of the deployer wallet (no 0x prefix)
PRIVATE_KEY=

# Arbiscan API key for contract verification (optional)
ARBISCAN_API_KEY=
